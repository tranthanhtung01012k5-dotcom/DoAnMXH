<?xml version="1.0" encoding="utf-8"?>
<!--
    res/values/styles.xml (hoặc themes.xml)
-->
<resources>

    <!-- Theme chính của app -->
    <style name="Theme.ThreadsClone" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/text_primary</item>
        <item name="colorSurface">@color/bg_surface</item>
        <item name="android:windowBackground">@color/bg_primary</item>
        <item name="android:statusBarColor">@color/bg_primary</item>
        <item name="android:navigationBarColor">@color/bg_primary</item>
        <!-- Icon status bar tối (nền sáng) -->
        <item name="android:windowLightStatusBar">true</item>
    </style>
    <style name="RoundedEditText">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">24dp</item>
    </style>
    <!-- ShapeOverlay: hình tròn cho avatar -->
    <style name="ShapeCircle" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <!-- ShapeOverlay: bo góc 12dp cho ảnh bài đăng -->
    <style name="ShapeRounded12" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>
    <style name="CircleImageView">
        <item name="cornerSize">50%</item>
    </style>
</resources>
