<?xml version="1.0" encoding="utf-8"?>
<!--
    item_notification.xml  –  Threads-style notification row
    ┌─────────────────────────────────────────────────────────────┐
    │  [unread dot] [avatar + type icon]  name · time      [···]  │
    │                                     content text            │
    │                                     [post snippet / image]  │
    │                                     [Theo dõi button]       │
    └─────────────────────────────────────────────────────────────┘
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="12dp"
    android:paddingBottom="12dp"
    android:background="@color/bg_primary"
    android:clickable="true"
    android:focusable="true">

    <!-- ── Chấm xanh "chưa đọc" ── -->
    <View
        android:id="@+id/unreadDot"
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:background="@drawable/shape_unread_dot"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/avatarContainer"
        app:layout_constraintBottom_toBottomOf="@id/avatarContainer"
        tools:visibility="visible"/>

    <!-- ── Avatar container (avatar + icon loại thông báo ở góc dưới-phải) ── -->
    <FrameLayout
        android:id="@+id/avatarContainer"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        app:layout_constraintStart_toEndOf="@id/unreadDot"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Avatar tròn -->
        <ImageView
            android:id="@+id/ivAvatar"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_person_outline_24"/>

        <!-- Icon loại thông báo (❤️ / follow / comment...) -->
        <ImageView
            android:id="@+id/ivTypeIcon"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_gravity="bottom|end"
            android:background="@drawable/bg_type_icon"
            android:padding="3dp"
            android:src="@drawable/ic_heart_filled_24"
            android:visibility="gone"
            tools:visibility="visible"/>

    </FrameLayout>

    <!-- ── Nội dung chính (cột phải) ── -->
    <LinearLayout
        android:id="@+id/contentLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintStart_toEndOf="@id/avatarContainer"
        app:layout_constraintEnd_toStartOf="@id/btnMore"
        app:layout_constraintTop_toTopOf="@id/avatarContainer">

        <!-- Hàng 1: tên + thời gian -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvUsername"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:ellipsize="end"
                android:maxLines="1"
                tools:text="nguyen_van_a"/>

            <TextView
                android:id="@+id/tvTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:textColor="#999999"
                android:textSize="12sp"
                tools:text="2 giờ"/>

        </LinearLayout>

        <!-- Hàng 2: nội dung thông báo -->

        <!-- Hàng 3: preview text bài viết -->
        <TextView
            android:id="@+id/tvContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:lineSpacingMultiplier="1.2"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            tools:text="đã thích bài viết của bạn." />

        <TextView
            android:id="@+id/tvPostSnippet"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#888888"
            android:textSize="12sp"
            android:maxLines="2"
            android:ellipsize="end"
            android:visibility="gone"
            tools:text="Hôm nay trời đẹp quá, đi uống cà phê thôi mọi người ơi..."/>

        <!-- Hàng 4: nút Theo dõi (chỉ hiện với type FOLLOW) -->

    </LinearLayout>

    <!-- ── Thumbnail bài viết (phải — chỉ hiện với LIKE / COMMENT / REPOST) ── -->

    <!-- ── Nút dấu ba chấm ── -->
    <ImageView
        android:id="@+id/btnMore"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:src="@drawable/ic_more"
        android:padding="2dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        app:tint="#AAAAAA"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/avatarContainer"
        app:layout_constraintBottom_toBottomOf="@id/avatarContainer"/>

</androidx.constraintlayout.widget.ConstraintLayout>