<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="12dp"
    android:paddingVertical="4dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:maxWidth="220dp"
        android:orientation="vertical">

        <!-- Reply Preview -->
        <LinearLayout
            android:id="@+id/layoutReplyPreview"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_reply_preview_me"
            android:padding="6dp"
            android:visibility="gone">

            <View
                android:layout_width="4dp"
                android:layout_height="match_parent"
                android:background="@drawable/reply_bar"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="8dp">

                <TextView
                    android:id="@+id/txtReplyPreviewName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#A78BFA"
                    android:textSize="12sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/txtReplyPreviewContent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"/>
            </LinearLayout>

        </LinearLayout>

        <!-- Video -->
        <FrameLayout
            android:layout_width="180dp"
            android:layout_height="240dp"
            android:layout_marginTop="4dp">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/imgVideoThumbnail"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                app:shapeAppearanceOverlay="@style/RoundedImageStyle"
                xmlns:app="http://schemas.android.com/apk/res-auto"/>

            <ImageView
                android:id="@+id/btnPlayVideo"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_play_circle_24"/>
        </FrameLayout>

        <!-- Reaction -->
        <TextView
            android:id="@+id/txtReaction"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="end"
            android:layout_marginTop="-8dp"
            android:layout_marginEnd="6dp"
            android:background="@drawable/bg_reaction"
            android:gravity="center"
            android:textSize="14sp"
            android:visibility="gone"/>

        <!-- Time + Read -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginTop="4dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtReadReceipt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="4dp"
                android:textColor="#8E8E93"
                android:textSize="11sp"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/txtMessageTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="#8E8E93"
                android:textSize="11sp"/>
        </LinearLayout>

    </LinearLayout>

    <!-- Các view bắt buộc cho ViewHolder -->

    <TextView
        android:id="@+id/txtMessageContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"/>

    <ImageView
        android:id="@+id/imgSenderAvatar"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"/>

    <TextView
        android:id="@+id/txtSenderName"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"/>

</LinearLayout>