<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/profileFragment"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- ================================================= -->
    <!-- TOP BAR -->
    <!-- ================================================= -->

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp">

        <ImageView
            android:id="@+id/btn_cancel"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_alignParentStart="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="2dp"
            android:src="@drawable/ic_arrow_back_24"
            app:tint="#FFFFFF" />

        <ImageView
            android:id="@+id/btnShareProfile"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_alignParentEnd="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="2dp"
            android:src="@drawable/ic_circle_more"
            app:tint="#FFFFFF" />

    </RelativeLayout>

    <!-- ================================================= -->
    <!-- PROFILE INFO -->
    <!-- ================================================= -->

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_toStartOf="@id/imgProfile"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:text="Keng Nguyễn"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/txtUsername"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="phaidaucuoctinh_005"
                    android:textColor="#B0B0B0"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="#1C1C1E"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:text="threads.net"
                    android:textColor="#8E8E93"
                    android:textSize="11sp" />

            </LinearLayout>

        </LinearLayout>

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imgProfile"
            android:layout_width="78dp"
            android:layout_height="78dp"
            android:layout_alignParentEnd="true"
            android:clickable="true"
            android:focusable="true"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_placeholder_avatar"
            app:shapeAppearanceOverlay="@style/CircleImageView"
            app:strokeColor="#2A2A2A"
            app:strokeWidth="1dp" />

    </RelativeLayout>

    <!-- ================================================= -->
    <!-- BIO -->
    <!-- ================================================= -->

    <TextView
        android:id="@+id/txtTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:lineSpacingExtra="4dp"
        android:text="Tình yêu thật\nThế giới ảo"
        android:textColor="#FFFFFF"
        android:textSize="15sp" />

    <!-- ================================================= -->
    <!-- FOLLOWERS -->
    <!-- ================================================= -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/layoutFollowingAvatars"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="10dp"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:orientation="horizontal" />

        <TextView
            android:id="@+id/txtSoNguoiTheoDoi"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 người theo dõi"
            android:textColor="#8E8E93"
            android:textSize="14sp" />

    </LinearLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFollow"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:backgroundTint="#1C1C1E"
            android:paddingVertical="10dp"
            android:text="Follow"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            app:cornerRadius="9dp"
            app:strokeColor="#2C2C2E"
            app:strokeWidth="0.5dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMessage"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:backgroundTint="#1C1C1E"
            android:paddingVertical="10dp"
            android:text="Nhắn tin"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            app:cornerRadius="9dp"
            app:strokeColor="#2C2C2E"
            app:strokeWidth="0.5dp" />
    </LinearLayout>

    <!-- ================================================= -->
    <!-- TABS -->
    <!-- ================================================= -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="26dp"
        android:orientation="horizontal">

        <!-- POSTS -->

        <LinearLayout
            android:id="@+id/btnPost"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtTabPost"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingVertical="12dp"
                android:text="Threads"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />

            <View
                android:id="@+id/linePost"
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="#FFFFFF" />

        </LinearLayout>

        <!-- COMMENTS -->

        <LinearLayout
            android:id="@+id/btnComment"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtTabComment"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingVertical="12dp"
                android:text="Câu trả lời"
                android:textColor="#636366"
                android:textSize="15sp"
                android:textStyle="bold" />

            <View
                android:id="@+id/lineComment"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#1C1C1E" />

        </LinearLayout>

        <!-- REPOST -->

        <LinearLayout
            android:id="@+id/btnRepost"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtTabRepost"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingVertical="12dp"
                android:text="Đăng lại"
                android:textColor="#636366"
                android:textSize="15sp"
                android:textStyle="bold" />

            <View
                android:id="@+id/lineRepost"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#1C1C1E" />

        </LinearLayout>

    </LinearLayout>

    <!-- ================================================= -->
    <!-- POSTS LIST -->
    <!-- ================================================= -->

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMyThreads"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="6dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:paddingBottom="20dp" />

</LinearLayout>