<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet"
    android:paddingBottom="12dp">

    <!-- HEADER: thông tin người dùng -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/headerAvatar"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_person_outline_24"
            android:scaleType="centerCrop" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="12dp">

            <TextView
                android:id="@+id/headerUsername"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />

            <TextView
                android:id="@+id/headerLastMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="#8E8E93"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="0.5dp"
        android:background="#3A3A3A" />

    <!-- Đánh dấu là chưa đọc -->
    <LinearLayout
        android:id="@+id/btnDanhDauChuaDoc"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:gravity="center_vertical"
        android:background="@color/bg_primary">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Lưu trữ tin nhắn"
            android:textColor="@color/text_secondary"
            android:textSize="16sp" />

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_mark_unread"
            android:tint="@color/text_secondary" />
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="0.5dp"
        android:background="#3A3A3A" android:layout_marginStart="20dp" android:layout_marginEnd="20dp"/>

    <!-- Tắt -->
    <LinearLayout
        android:id="@+id/btnTat"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:gravity="center_vertical"
        android:background="@color/bg_primary">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Tắt thông báo"
            android:textSize="16sp"
            android:textColor="@color/text_secondary" />

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_not_ications"
            android:tint="@color/text_secondary" />
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="0.5dp"
        android:background="#3A3A3A" android:layout_marginStart="20dp" android:layout_marginEnd="20dp"/>

    <!-- Ghim -->
    <LinearLayout
        android:id="@+id/btnGhim"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:gravity="center_vertical"
        android:background="@color/bg_primary">

        <TextView
            android:id ="@+id/tvGhim"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Ghim"
            android:textSize="16sp"
            android:textColor="@color/text_secondary" />

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_push_pin"
            android:tint="@color/text_secondary" />
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="0.5dp"
        android:background="#3A3A3A" android:layout_marginStart="20dp" android:layout_marginEnd="20dp"/>

    <!-- Xóa -->
    <LinearLayout
        android:id="@+id/btnXoa"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:gravity="center_vertical"
        android:background="?attr/selectableItemBackground">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Xóa"
            android:textSize="16sp"
            android:textColor="#FF3B30" />

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_delete"
            android:tint="#FF3B30" />
    </LinearLayout>

</LinearLayout>