<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/profileFragment"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:orientation="vertical"
    android:paddingHorizontal="20dp"
    android:paddingTop="16dp"
    android:paddingBottom="8dp">

    <!-- Thanh Action Bar Trên Cùng -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp">

        <ImageView
            android:id="@+id/btnLanguage"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentStart="true"
            android:layout_centerInParent="true"
            android:contentDescription="Web Icon"
            android:src="@drawable/ic_language"
            app:tint="@color/action_icon" />

        <ImageView
            android:id="@+id/btnMenu"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentEnd="true"
            android:layout_centerInParent="true"
            android:contentDescription="Menu Icon"
            android:src="@drawable/ic_menu"
            app:tint="@color/action_icon" />
    </RelativeLayout>

    <!-- Khu vực Thông tin cá nhân (Tên, Username, Avatar) -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:layout_toStartOf="@id/imgProfile"
            android:layout_marginEnd="16dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Keng Nguyễn"
                android:textColor="@color/text_primary"
                android:textSize="24sp"
                android:textStyle="bold"
                android:letterSpacing="-0.02" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/txtUsername"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="phaidaucuoctinh_005"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_badge_threads"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="3dp"
                    android:text="threads.net"
                    android:textColor="#8E8E93"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imgProfile"
            android:layout_width="68dp"
            android:layout_height="68dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_placeholder_avatar"
            app:shapeAppearanceOverlay="@style/CircleImageView"
            app:strokeColor="@color/divider"
            app:strokeWidth="1dp" />
    </RelativeLayout>

    <!-- Tiểu sử (Bio) -->
    <TextView
        android:id="@+id/txtTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:lineSpacingMultiplier="1.2"
        android:text="Tình yêu thật\nThế giới ảo"
        android:textColor="#E5E5EA"
        android:textSize="14sp" />

    <!-- Người theo dõi (Followers) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/layoutFollowingAvatars"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:orientation="horizontal" />

        <TextView
            android:id="@+id/txtSoNguoiTheoDoi"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 người theo dõi"
            android:textColor="#8E8E93"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Nút Chức năng (Bo tròn mềm mại) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEditProfile"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:backgroundTint="@color/bg_surface"
            android:paddingVertical="10dp"
            android:text="Chỉnh sửa hồ sơ"
            android:textAllCaps="false"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            app:cornerRadius="9dp"
            app:strokeColor="#2C2C2E"
            app:strokeWidth="0.5dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnShareProfile"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:backgroundTint="@color/bg_surface"
            android:paddingVertical="10dp"
            android:text="Chia sẻ hồ sơ"
            android:textAllCaps="false"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            app:cornerRadius="9dp"
            app:strokeColor="#2C2C2E"
            app:strokeWidth="0.5dp" />
    </LinearLayout>

    <!-- Thanh Tabs điều hướng -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:orientation="horizontal">

        <!-- Tab Threads -->
        <LinearLayout
            android:id="@+id/btnPost"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtTabPost"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingVertical="10dp"
                android:text="Threads"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <View
                android:id="@+id/linePost"
                android:layout_width="match_parent"
                android:layout_height="1.5dp"
                android:background="@color/text_primary" />
        </LinearLayout>

        <!-- Tab Câu trả lời -->
        <LinearLayout
            android:id="@+id/btnComment"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtTabComment"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingVertical="10dp"
                android:text="Câu trả lời"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <View
                android:id="@+id/lineComment"
                android:layout_width="match_parent"
                android:layout_height="1.5dp"
                android:background="@color/divider" />
        </LinearLayout>

        <!-- Tab Đăng lại -->
        <LinearLayout
            android:id="@+id/btnRepost"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtTabRepost"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingVertical="10dp"
                android:text="Đăng lại"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <View
                android:id="@+id/lineRepost"
                android:layout_width="match_parent"
                android:layout_height="1.5dp"
                android:background="@color/divider" />
        </LinearLayout>

    </LinearLayout>
    <!-- Danh sách hiển thị nội dung -->
    <!-- Thêm paddingBottom cho FrameLayout hoặc trực tiếp vào RecyclerView -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <TextView
            android:id="@+id/txtEmptyMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Bạn chưa đăng Thread nào."
            android:textColor="@color/text_secondary"
            android:textSize="15sp" />

        <!--
           Sửa ở đây:
           1. Thêm paddingBottom="60dp" (khoảng cách vừa vặn thanh bottom nav)
           2. Thêm clipToPadding="false" để khi cuộn lên hết cỡ, item cuối cùng vẫn nằm trên thanh bar rõ ràng.
        -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvMyThreads"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingBottom="60dp"
            android:clipToPadding="false"
            android:nestedScrollingEnabled="true" />

    </FrameLayout>

</LinearLayout>
