<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingHorizontal="12dp"
    android:paddingVertical="4dp">

    <!-- Avatar -->
    <ImageView
        android:id="@+id/imgSenderAvatar"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:layout_gravity="top"
        android:layout_marginEnd="8dp"
        android:background="@drawable/bg_avatar_circle"
        android:padding="1dp"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_person_outline_24" />

    <!-- Nội dung tin nhắn -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Tên người gửi -->
        <TextView
            android:id="@+id/txtSenderName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginBottom="2dp"
            android:text="Nguyễn Văn A"
            android:textColor="#8E8E93"
            android:textSize="12sp"
            android:textStyle="bold" />

        <!-- Reply -->
        <LinearLayout
            android:id="@+id/layoutReplyPreview"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="2dp"
            android:visibility="gone">

        </LinearLayout>

        <!-- Bubble + Image -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtMessageContent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxWidth="270dp"
                android:background="@drawable/bg_bubble_other"
                android:paddingHorizontal="14dp"
                android:paddingVertical="10dp"
                android:textColor="#FFFFFF"
                android:textSize="14sp" />

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/imgMessageContent"
                android:layout_width="220dp"
                android:layout_height="220dp"
                android:layout_marginTop="2dp"
                android:scaleType="centerCrop"
                android:visibility="gone"
                app:shapeAppearanceOverlay="@style/RoundedImageStyle" />

            <TextView
                android:id="@+id/txtReaction"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginStart="8dp"
                android:layout_marginTop="-10dp"
                android:background="@drawable/bg_reaction"
                android:gravity="center"
                android:textSize="14sp"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Time -->
        <TextView
            android:id="@+id/txtMessageTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginTop="2dp"
            android:text="10:30"
            android:textColor="#8E8E93"
            android:textSize="11sp" />

    </LinearLayout>

</LinearLayout>