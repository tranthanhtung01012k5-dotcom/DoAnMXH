<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <!-- ───────────────────────────── HEADER ───────────────────────────── -->
    <RelativeLayout
        android:id="@+id/headerNoteEditor"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="8dp"
        android:paddingEnd="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="10dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:layout_centerVertical="true"
            android:padding="2dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:contentDescription="Đóng"
            app:tint="@color/text_primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Ghi chú"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnShareNote"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_share_note_btn"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:text="Chia sẻ"
            android:textColor="@color/button_primary_text"
            android:textSize="14sp"
            android:textStyle="bold"
            android:enabled="false"
            android:alpha="0.5" />

    </RelativeLayout>

    <!-- ───────────────────────────── PREVIEW ───────────────────────────── -->
    <LinearLayout
        android:id="@+id/layoutPreview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/headerNoteEditor"
        android:layout_marginTop="24dp"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <!-- Bong bóng xem trước nội dung ghi chú -->
        <FrameLayout
            android:id="@+id/flPreviewBubble"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="-6dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvPreviewNote"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:minWidth="60dp"
                android:maxWidth="220dp"
                android:background="@drawable/bg_note_bubble"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:text=""
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:maxLines="3"
                android:ellipsize="end"
                android:gravity="center" />

            <View
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="-7dp"
                android:background="@drawable/bg_note_bubble_tail"
                android:rotation="45" />
        </FrameLayout>

        <!-- Avatar người dùng -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imgPreviewAvatar"
            android:layout_width="84dp"
            android:layout_height="84dp"
            android:layout_marginTop="6dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_placeholder_avatar"
            app:shapeAppearanceOverlay="@style/CircleImageView" />

    </LinearLayout>

    <!-- ───────────────────────────── Ô NHẬP GHI CHÚ ───────────────────────────── -->
    <LinearLayout
        android:id="@+id/layoutInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/layoutPreview"
        android:layout_marginTop="20dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:background="@drawable/bg_note_input"
        android:orientation="vertical"
        android:padding="14dp">

        <EditText
            android:id="@+id/edtNoteContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            android:gravity="center"
            android:hint="Bạn đang nghĩ gì?"
            android:importantForAutofill="no"
            android:inputType="textCapSentences|textMultiLine"
            android:maxLength="60"
            android:maxLines="3"
            android:minHeight="48dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/tvCharCount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="end"
            android:text="0/60"
            android:textColor="@color/text_secondary"
            android:textSize="11sp" />

    </LinearLayout>

    <!-- ───────────────────────────── GỢI Ý NHANH ───────────────────────────── -->
    <HorizontalScrollView
        android:id="@+id/scrollSuggestions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/layoutInput"
        android:layout_marginTop="18dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/layoutSuggestions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal" />

    </HorizontalScrollView>

    <!-- ───────────────────────────── XÓA GHI CHÚ HIỆN TẠI ───────────────────────────── -->
    <TextView
        android:id="@+id/btnRemoveNote"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/scrollSuggestions"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="24dp"
        android:padding="8dp"
        android:text="Xóa ghi chú hiện tại"
        android:textColor="#B3261E"
        android:textSize="14sp"
        android:textStyle="bold"
        android:visibility="gone" />

</RelativeLayout>