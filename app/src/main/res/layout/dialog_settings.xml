<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/settingsRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:clipToOutline="true"
    android:elevation="16dp"
    android:orientation="vertical"
    android:paddingHorizontal="20dp"
    android:paddingTop="14dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="48dp">

        <TextView
            android:id="@+id/txtSettingsTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Cài đặt"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/btnCloseSettings"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Đóng cài đặt"
            android:padding="5dp"
            android:src="@drawable/ic_close"
            app:tint="@color/action_icon" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="28dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtSectionAccountInfo"
                style="@style/SettingsSectionTitle"
                android:text="Thông tin tài khoản" />

            <LinearLayout
                android:id="@+id/sectionAccountInfo"
                style="@style/SettingsSection">

                <TextView
                    android:id="@+id/rowChangePassword"
                    style="@style/SettingsRow"
                    android:text="Đổi mật khẩu" />
            </LinearLayout>

            <TextView
                android:id="@+id/txtSectionMyActivity"
                style="@style/SettingsSectionTitle"
                android:text="Hoạt động của tôi" />

            <LinearLayout
                android:id="@+id/sectionMyActivity"
                style="@style/SettingsSection">

                <TextView
                    android:id="@+id/rowLikedPosts"
                    style="@style/SettingsRow"
                    android:text="Bài viết đã thích" />

                <View style="@style/SettingsDivider" />

                <TextView
                    android:id="@+id/rowLikedComments"
                    style="@style/SettingsRow"
                    android:text="Bình luận đã thích" />
            </LinearLayout>

            <TextView
                android:id="@+id/txtSectionContent"
                style="@style/SettingsSectionTitle"
                android:text="Nội dung của bạn" />

            <LinearLayout
                android:id="@+id/sectionContent"
                style="@style/SettingsSection">

                <TextView
                    android:id="@+id/rowSavedPosts"
                    style="@style/SettingsRow"
                    android:text="Đã lưu" />

                <View style="@style/SettingsDivider" />

                <TextView
                    android:id="@+id/rowArchive"
                    style="@style/SettingsRow"
                    android:text="Kho lưu trữ" />
            </LinearLayout>

            <TextView
                android:id="@+id/txtSectionPrivacy"
                style="@style/SettingsSectionTitle"
                android:text="Quyền riêng tư" />

            <LinearLayout
                android:id="@+id/sectionPrivacy"
                style="@style/SettingsSection">

                <LinearLayout
                    android:id="@+id/rowPrivateAccount"
                    style="@style/SettingsSwitchRow">

                    <TextView
                        android:id="@+id/txtPrivateAccountLabel"
                        style="@style/SettingsRowText"
                        android:text="Tài khoản riêng tư" />

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switchPrivateAccount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <View style="@style/SettingsDivider" />

                <TextView
                    android:id="@+id/rowBlockedUsers"
                    style="@style/SettingsRow"
                    android:text="Chặn người dùng" />
            </LinearLayout>

            <TextView
                android:id="@+id/txtSectionAccountStatus"
                style="@style/SettingsSectionTitle"
                android:text="Trạng thái tài khoản" />

            <LinearLayout
                android:id="@+id/sectionAccountStatus"
                style="@style/SettingsSection">

                <TextView
                    android:id="@+id/rowAccountStatus"
                    style="@style/SettingsRow"
                    android:text="Thông tin đăng nhập và hồ sơ" />
            </LinearLayout>

            <TextView
                android:id="@+id/txtSectionAppearance"
                style="@style/SettingsSectionTitle"
                android:text="Giao diện" />

            <LinearLayout
                android:id="@+id/sectionAppearance"
                style="@style/SettingsSection">

                <LinearLayout
                    android:id="@+id/rowDarkMode"
                    style="@style/SettingsSwitchRow">

                    <TextView
                        android:id="@+id/txtLightModeLabel"
                        style="@style/SettingsRowText"
                        android:text="Chế độ tối" />

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switchDarkMode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="false" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/txtSectionNotifications"
                style="@style/SettingsSectionTitle"
                android:text="Thông báo" />

            <LinearLayout
                android:id="@+id/sectionNotifications"
                style="@style/SettingsSection">

                <LinearLayout
                    android:id="@+id/rowNotifications"
                    style="@style/SettingsSwitchRow">

                    <TextView
                        android:id="@+id/txtNotificationsLabel"
                        style="@style/SettingsRowText"
                        android:text="Bật thông báo" />

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switchNotifications"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/txtSectionSupport"
                style="@style/SettingsSectionTitle"
                android:text="Hỗ trợ" />

            <LinearLayout
                android:id="@+id/sectionSupport"
                style="@style/SettingsSection">

                <TextView
                    android:id="@+id/rowTerms"
                    style="@style/SettingsRow"
                    android:text="Điều khoản sử dụng" />

                <View style="@style/SettingsDivider" />

                <TextView
                    android:id="@+id/rowPrivacyPolicy"
                    style="@style/SettingsRow"
                    android:text="Chính sách bảo mật" />
            </LinearLayout>

            <TextView
                android:id="@+id/txtSectionOther"
                style="@style/SettingsSectionTitle"
                android:text="Cài đặt khác" />

            <LinearLayout
                android:id="@+id/sectionOther"
                style="@style/SettingsSection">

<!--                <TextView-->
<!--                    android:id="@+id/rowLanguage"-->
<!--                    style="@style/SettingsRow"-->
<!--                    android:text="Ngôn ngữ" />-->

<!--                <View style="@style/SettingsDivider" />-->

                <TextView
                    android:id="@+id/rowAbout"
                    style="@style/SettingsRow"
                    android:text="Giới thiệu" />
            </LinearLayout>

            <!-- Thay thế đoạn sectionLogout trong file layout Settings của bạn -->
            <!-- Thêm row "Chuyển tài khoản" NGAY TRÊN row "Đăng xuất" -->

            <TextView
                android:id="@+id/txtSectionLogout"
                style="@style/SettingsSectionTitle"
                android:text="Tài khoản" />

            <LinearLayout
                android:id="@+id/sectionLogout"
                style="@style/SettingsSection">

                <!-- ✅ THÊM MỚI: Chuyển tài khoản -->
                <TextView
                    android:id="@+id/rowSwitchAccount"
                    style="@style/SettingsRow"
                    android:text="Chuyển tài khoản" />

                <View style="@style/SettingsDivider" />

                <!-- Đăng xuất (giữ nguyên) -->
                <TextView
                    android:id="@+id/rowLogout"
                    style="@style/SettingsRow"
                    android:text="Đăng xuất"
                    android:textColor="#FF453A" />

            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
