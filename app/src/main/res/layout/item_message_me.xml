<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="12dp"
    android:paddingVertical="4dp">

    <!-- Container bubble -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:maxWidth="270dp"
        android:orientation="vertical"
        android:paddingTop="2dp"
        android:paddingBottom="10dp">

        <!-- REPLY PREVIEW -->
        <LinearLayout
            android:id="@+id/layoutReplyPreview"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="0dp"            android:orientation="horizontal"
            android:background="@drawable/bg_reply_preview_me"
            android:padding="6dp"
            android:visibility="gone">

            <View
                android:layout_width="4dp"
                android:layout_height="match_parent"
                android:background="@drawable/reply_bar"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="8dp"
                android:paddingTop="4dp"
                android:paddingEnd="8dp"
                android:paddingBottom="4dp">

                <TextView
                    android:id="@+id/txtReplyPreviewName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxWidth="240dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="#A78BFA"
                    android:textSize="12sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/txtReplyPreviewContent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxWidth="240dp"
                    android:maxLines="3"
                    android:ellipsize="end"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- TEXT MESSAGE -->
        <TextView
            android:id="@+id/txtMessageContent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:background="@drawable/bg_bubble_me"
            android:lineSpacingExtra="2dp"
            android:paddingHorizontal="14dp"
            android:paddingVertical="10dp"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:includeFontPadding="false"/>

        <!-- REACTION -->
        <TextView
            android:id="@+id/txtReaction"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="end"
            android:layout_marginTop="-8dp"
            android:layout_marginEnd="6dp"
            android:background="@drawable/bg_reaction"
            android:gravity="center"
            android:textSize="14sp"
            android:visibility="gone"/>

        <!-- IMAGE MESSAGE -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imgMessageContent"
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:scaleType="centerCrop"
            android:visibility="gone"
            android:layout_marginTop="4dp"
            app:shapeAppearanceOverlay="@style/RoundedImageStyle" />

        <!-- TIME + READ STATUS -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="2dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtReadReceipt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="4dp"
                android:text="Đã xem"
                android:textColor="#8E8E93"
                android:textSize="11sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/txtMessageTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="#8E8E93"
                android:textSize="11sp" />
        </LinearLayout>

    </LinearLayout>
</LinearLayout>